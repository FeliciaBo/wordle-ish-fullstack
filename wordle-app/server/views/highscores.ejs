<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Highscores</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/highscores.css" />
  </head>
  <body>
    <main>
      <a href="/">Back to game</a>
      <h1>Highscores</h1>

      <form method="GET" action="/highscores">
        <div>
          <label for="length">Word length:</label>
          <input
            id="length"
            type="number"
            name="length"
            min="1"
            value="<%= filters.length %>"
          />
        </div>

        <div>
          <label for="unique">Unique letters:</label>
          <select id="unique" name="unique">
            <option value="" <%= filters.unique === "" ? "selected" : "" %>>
              All
            </option>
            <option value="true" <%= filters.unique === "true" ? "selected" : "" %>>
              Yes
            </option>
            <option value="false" <%= filters.unique === "false" ? "selected" : "" %>>
              No
            </option>
          </select>
        </div>

        <button type="submit">Filter</button>
        <a href="/highscores">Clear filters</a>
      </form>

      <% if (highscores.length === 0) { %>
        <p>No highscores found for these filters.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Time</th>
              <th>Guesses</th>
              <th>Word length</th>
              <th>Unique letters</th>
            </tr>
          </thead>
          <tbody>
            <% highscores.forEach((score) => { %>
              <tr>
                <td><%= score.name %></td>
                <td><%= (score.timeMs / 1000).toFixed(2) %> s</td>
                <td><%= score.guessesCount %></td>
                <td><%= score.length %></td>
                <td><%= score.unique ? "Yes" : "No" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </main>
  </body>
</html>